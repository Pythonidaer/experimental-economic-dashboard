# Optional: canonical URL for metadata and sitemap (production).
# On Vercel you can omit this and rely on VERCEL_URL, or set your custom domain, e.g.:
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (required for Table + Charts). Values are exposed to the browser (NEXT_PUBLIC_).
# Dashboard → Project Settings → API: Project URL and anon (public) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
